<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!-- On macOS: copy lib7z.dylib from Homebrew into the repo runtimes folder (once) -->
  <Target Name="ProvisionNativeLibrary" BeforeTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <PropertyGroup>
      <_HomebrewLib>/opt/homebrew/lib/lib7z.dylib</_HomebrewLib>
      <_RuntimeNativeDir>$(MSBuildThisFileDirectory)..\..\runtimes\osx-arm64\native\</_RuntimeNativeDir>
    </PropertyGroup>
    <MakeDir Directories="$(_RuntimeNativeDir)"
             Condition="Exists('$(_HomebrewLib)') And !Exists('$(_RuntimeNativeDir)')" />
    <Copy SourceFiles="$(_HomebrewLib)"
          DestinationFiles="$(_RuntimeNativeDir)7z.dylib"
          Condition="Exists('$(_HomebrewLib)') And !Exists('$(_RuntimeNativeDir)7z.dylib')" />
  </Target>

  <!-- Copy whatever is in runtimes/ to the test output directory -->
  <Target Name="CopyNativeLibsToOutput" DependsOnTargets="ProvisionNativeLibrary"
          AfterTargets="Build">
    <ItemGroup>
      <!-- Use runtimes\**\* (no fixed 'native' suffix) so RecursiveDir captures the full
           RID+native sub-path (e.g. osx-arm64\native\) without any double-match. -->
      <_NativeLibs Include="$(MSBuildThisFileDirectory)..\..\runtimes\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_NativeLibs)"
          DestinationFiles="@(_NativeLibs->'$(OutDir)runtimes\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <EmbeddedResource Include="Fixtures\password-protected.7z" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8"/>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.6.0"/>
    <PackageReference Include="NUnit" Version="4.6.1"/>
    <PackageReference Include="NUnit3TestAdapter" Version="6.2.0"/>
    <PackageReference Include="AwesomeAssertions" Version="9.4.0"/>
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\SevenZipSharper\SevenZipSharper.csproj"/>
  </ItemGroup>

</Project>
